<Window x:Class="NXStartCenter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NX Start Center"
        Height="620"
        Width="900"
        MinHeight="560"
        MinWidth="820"
        WindowStartupLocation="CenterScreen">

    <DockPanel>

        <Border DockPanel.Dock="Top"
                Padding="16"
                Background="#1F2937">
            <StackPanel>
                <TextBlock Text="NX Start Center"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock Text="{Binding HeaderInfo}"
                           Foreground="#D1D5DB"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding CurrentUser}"/>
            </StatusBarItem>
        </StatusBar>

        <TabControl Margin="12">
            <TabItem Header="Einstellungen">
                <ScrollViewer Margin="12" VerticalScrollBarVisibility="Auto">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="NX Installationspfad:" Grid.Row="0" Grid.Column="0"/>
                        <TextBox Text="{Binding Settings.NxInstallationPath, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1"/>

                        <TextBlock Text="Kundenumgebungen:" Grid.Row="1" Grid.Column="0"/>
                        <TextBox Text="{Binding Settings.CustomerEnvironmentPath, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="1"/>

                        <TextBlock Text="Lizenzpfad:" Grid.Row="2" Grid.Column="0"/>
                        <TextBox Text="{Binding Settings.LicencePath, UpdateSourceTrigger=PropertyChanged}" Grid.Row="2" Grid.Column="1"/>

                        <TextBlock Text="Lizenzserver:" Grid.Row="3" Grid.Column="0"/>
                        <TextBox Text="{Binding Settings.LicenceServerPath, UpdateSourceTrigger=PropertyChanged}" Grid.Row="3" Grid.Column="1"/>

                        <TextBlock Text="Fork Pfad:" Grid.Row="4" Grid.Column="0"/>
                        <TextBox Text="{Binding Settings.ForkPath, UpdateSourceTrigger=PropertyChanged}" Grid.Row="4" Grid.Column="1"/>

                        <TextBlock Text="Rollenpfad:" Grid.Row="5" Grid.Column="0"/>
                        <TextBox Text="{Binding Settings.RolesPath, UpdateSourceTrigger=PropertyChanged}" Grid.Row="5" Grid.Column="1"/>

                        <TextBlock Text="Team:" Grid.Row="6" Grid.Column="0"/>
                        <ComboBox ItemsSource="{Binding Teams}"
                      SelectedItem="{Binding Settings.Team}"
                      Grid.Row="6"
                      Grid.Column="1"/>

                        <TextBlock Text="Theme:" Grid.Row="7" Grid.Column="0"/>
                        <ComboBox ItemsSource="{Binding Themes}"
                      SelectedItem="{Binding Settings.PreferredTheme}"
                      Grid.Row="7"
                      Grid.Column="1"/>

                        <TextBlock Text="Editor:" Grid.Row="8" Grid.Column="0"/>
                        <ComboBox ItemsSource="{Binding Editors}"
                      SelectedItem="{Binding Settings.Editor}"
                      Grid.Row="8"
                      Grid.Column="1"/>

                        <CheckBox Content="Startdatei debuggen"
                      IsChecked="{Binding Settings.StartNxWithDebug}"
                      Grid.Row="9"
                      Grid.Column="1"
                      Margin="0,8"/>

                        <Button Content="Einstellungen speichern"
                    Command="{Binding SaveSettingsCommand}"
                    Grid.Row="10"
                    Grid.Column="1"
                    Width="200"
                    HorizontalAlignment="Left"
                    Margin="0,16,0,0"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Projekt">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="Projekt weiterarbeiten">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Kunde:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding Customers}"
                          SelectedItem="{Binding SelectedCustomer}"
                          Grid.Row="0"
                          Grid.Column="1"
                          Margin="0,4"/>

                            <Button Content="Aktualisieren"
                        Command="{Binding RefreshCustomersCommand}"
                        Grid.Row="0"
                        Grid.Column="2"
                        Margin="8,4,0,4"/>

                            <TextBlock Text="NX-Version:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding Versions}"
                          SelectedItem="{Binding SelectedVersion}"
                          Grid.Row="1"
                          Grid.Column="1"
                          Margin="0,4"/>

                            <TextBlock Text="Maschine:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding Machines}"
                          SelectedItem="{Binding SelectedMachine}"
                          Grid.Row="2"
                          Grid.Column="1"
                          Margin="0,4"/>

                            <Button Content="NX starten"
                        Command="{Binding StartCustomerNxCommand}"
                        Grid.Row="3"
                        Grid.Column="1"
                        Width="160"
                        HorizontalAlignment="Left"
                        Margin="0,12,0,0"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Neues Projekt anlegen" Grid.Row="1">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Kunde:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding Customers}"
                          Text="{Binding NewCustomer}"
                          IsEditable="True"
                          Grid.Row="0"
                          Grid.Column="1"
                          Margin="0,4"/>

                            <TextBlock Text="NX-Version:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding NativeVersions}"
                          SelectedItem="{Binding NewVersion}"
                          Grid.Row="1"
                          Grid.Column="1"
                          Margin="0,4"/>

                            <TextBlock Text="Maschine:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding NewMachine, UpdateSourceTrigger=PropertyChanged}"
                         Grid.Row="2"
                         Grid.Column="1"
                         Margin="0,4"/>

                            <TextBlock Text="Auftragsnummer:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding NewOrderNumber, UpdateSourceTrigger=PropertyChanged}"
                         Grid.Row="3"
                         Grid.Column="1"
                         Margin="0,4"/>

                            <Button Content="Projekt erstellen"
                        Command="{Binding CreateProjectCommand}"
                        Grid.Row="4"
                        Grid.Column="1"
                        Width="180"
                        HorizontalAlignment="Left"
                        Margin="0,12,0,0"/>
                        </Grid>
                    </GroupBox>

                    <TextBlock Text="{Binding CurrentProjectPath}"
                   Grid.Row="2"
                   Margin="8"
                   TextWrapping="Wrap"/>
                </Grid>
            </TabItem>

            <TabItem Header="Start">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="NX starten" Grid.Column="0">
                        <StackPanel>
                            <Button Content="NX Native starten"
                                    Command="{Binding StartNxNativeCommand}"/>

                            <Button Content="Kunden-NX starten"
                                    Command="{Binding StartCustomerNxCommand}"/>

                            <Button Content="Postbuilder starten"
                                    Command="{Binding StartPostbuilderCommand}"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Tools" Grid.Column="1">
                        <StackPanel>
                            <Button Content="Explorer öffnen"
                                    Command="{Binding OpenExplorerCommand}"/>

                            <Button Content="VS Code öffnen"
                                    Command="{Binding OpenVsCodeCommand}"/>

                            <Button Content="Fork öffnen"
                                    Command="{Binding OpenForkCommand}"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Projekt">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="Neues Projekt erstellen">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Kunde:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"
                                     Grid.Row="0" Grid.Column="1"
                                     Margin="0,4"/>

                            <TextBlock Text="Maschine:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding MachineName, UpdateSourceTrigger=PropertyChanged}"
                                     Grid.Row="1" Grid.Column="1"
                                     Margin="0,4"/>

                            <Button Content="Projekt erstellen"
                                    Command="{Binding CreateProjectCommand}"
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    HorizontalAlignment="Left"
                                    Width="180"
                                    Margin="0,12,0,0"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Aktuelles Projekt" Grid.Row="1">
                        <TextBlock Text="{Binding CurrentProjectPath}"
                                   TextWrapping="Wrap"/>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Lizenz">
                <GroupBox Header="Lizenzverwaltung" Margin="16">
                    <StackPanel>
                        <Button Content="Lizenzordner öffnen"
                                Command="{Binding OpenLicenseFolderCommand}"/>

                        <Button Content="LMTools starten"
                                Command="{Binding StartLmToolsCommand}"/>
                    </StackPanel>
                </GroupBox>
            </TabItem>

            <TabItem Header="Info">
                <GroupBox Header="App-Informationen" Margin="16">
                    <StackPanel>
                        <TextBlock Text="{Binding AppVersion}" Margin="0,4"/>
                        <TextBlock Text="{Binding AppDate}" Margin="0,4"/>
                        <TextBlock Text="{Binding AppAuthor}" Margin="0,4"/>
                        <TextBlock Text="{Binding AppSupportMail}" Margin="0,4"/>
                    </StackPanel>
                </GroupBox>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>