<Window x:Class="NXStartCenter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="d.u.h. Start Center"
        Height="630"
        Width="733"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        >

    <Border BorderBrush="#3A3A3A"
        BorderThickness="3"
        CornerRadius="15"
        Background="Transparent"
        ClipToBounds="True" Cursor="">
        <Grid Background="{StaticResource BgMain}">

            <Image Source="pack://application:,,,/resources/images/duhGroup_Logo.png"
           Width="120"
           Height="120"
           HorizontalAlignment="Right"
           VerticalAlignment="Top"
           Margin="0,25,70,0"
           Opacity="0.80"
           IsHitTestVisible="False"
           Panel.ZIndex="2"/>

            <DockPanel Panel.ZIndex="1">

                <!-- Titelleiste -->
                <Border DockPanel.Dock="Top"
                Background="#1E1E1E"
                CornerRadius="12,12,0,0">

                    <Grid Height="36"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="45"/>
                            <ColumnDefinition Width="45"/>
                        </Grid.ColumnDefinitions>

                        <Image Source="pack://application:,,,/resources/images/duhGroup_Logo.ico"
Width="30"
Height="30"
HorizontalAlignment="Left"
VerticalAlignment="Top"
Margin="5,4,0,0"
Opacity="0.99"
IsHitTestVisible="False"
Panel.ZIndex="5"/>

                        <TextBlock Text="         d.u.h. Start Center"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           Foreground="White"
                           FontWeight="SemiBold"/>

                        <Button Grid.Column="1"
        Content="—"
        FontSize="16"
        Width="36"
        Height="28"
        Margin="0,4,4,4"
        Style="{StaticResource TitleBarButtonStyle}"
        Click="Minimize_Click"/>

                        <Button Grid.Column="2"
        Content="✕"
        FontSize="14"
        Width="36"
        Height="28"
        Margin="0,4,6,4"
        Style="{StaticResource CloseTitleBarButtonStyle}"
        Click="Close_Click"/>
                    </Grid>
                </Border>


    <Menu DockPanel.Dock="Top">
            <MenuItem Header="Datei">
                <MenuItem Header="Aktualisieren" Command="{Binding RefreshCommand}"/>
                <Separator/>
                <MenuItem Header="Beenden" Click="Exit_Click"/>
            </MenuItem>

            <MenuItem Header="Lizenz">
                <MenuItem Header="Lizenzdatei öffnen" Command="{Binding OpenLicenseFileCommand}"/>
                <MenuItem Header="LMTools starten" Command="{Binding StartLmToolsCommand}"/>
            </MenuItem>

            <MenuItem Header="Einstellungen">
                <MenuItem Header="Einstellungen öffnen" Command="{Binding OpenSettingsCommand}"/>
                <MenuItem Header="Einstellungen speichern" Command="{Binding SaveSettingsCommand}"/>
            </MenuItem>

            <MenuItem Header="Start Batches">
                <MenuItem Header="Startbatch öffnen" Command="{Binding OpenMainBatch}"/>
                        <MenuItem Header="Kundenbatch öffnen" Command="{Binding OpenCustomerBatch}"/>
                        <MenuItem Header="Developerbatch öffnen" Command="{Binding OpenMainBatch}"/>
            </MenuItem>

            <MenuItem Header="Info" Command="{Binding ShowInfoCommand}"/>
        </Menu>

                <Border DockPanel.Dock="Bottom"
                Background="#252525"
                CornerRadius="0,0,12,12"
                Padding="4,0">

                    <StatusBar Background="Transparent"
                       BorderThickness="0">

                        <StatusBarItem Width="250">
                            <TextBlock Text="{Binding StatusText}"
                               Foreground="{Binding StatusColor}"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding StatusText}"/>
                        </StatusBarItem>

                        <Separator/>

                        <StatusBarItem>
                            <TextBlock Text="{Binding CurrentProjectPath}"
                               Foreground="{StaticResource TextMuted}"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding CurrentProjectPath}"/>
                        </StatusBarItem>

                    </StatusBar>
                </Border>

                <Grid Margin="14">

            <TabControl Margin="0,-14,0,-14">

                <TabItem Header="Custom">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="226"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <GroupBox Header="Projekt auswählen" Grid.Row="0" Grid.Column="0" Margin="6,12,6,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="105"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>

                                        </Grid.RowDefinitions>

                                <TextBlock Text="Kunde:" Grid.Row="0" Grid.Column="0"/>
                                <ComboBox ItemsSource="{Binding Customers}"
                                          ScrollViewer.CanContentScroll="True"
                      SelectedItem="{Binding SelectedCustomer}"
                      Grid.Row="0"
                      Grid.Column="1"/>

                                <TextBlock Text="NX-Version:" Grid.Row="1" Grid.Column="0"/>
                                <ComboBox ItemsSource="{Binding Versions}"
                                          ScrollViewer.CanContentScroll="True"
                      SelectedItem="{Binding SelectedVersion}"
                      Grid.Row="1"
                      Grid.Column="1"/>

                                <TextBlock Text="Maschine:" Grid.Row="2" Grid.Column="0"/>
                                <ComboBox ItemsSource="{Binding Machines}"
                                          ScrollViewer.CanContentScroll="True"
                      SelectedItem="{Binding SelectedMachine}"
                      Grid.Row="2"
                      Grid.Column="1"/>

                                       
                                    </Grid>
                        </GroupBox>

                                <StackPanel Grid.Row="1"
            Grid.Column="0">

                                    <GroupBox Header="Ladeoptionen" Grid.Row="1" Grid.Column="0" Margin="6,0,6,12" Visibility="{Binding PpVisibility}">
                            <StackPanel>
                                            <CheckBox Style="{StaticResource ModernCheckBoxStyle}" Content="Gesamtes Resource Verzeichnis laden"
IsChecked="{Binding LoadFullResourceDir}" Margin="0,2,0,2"/>
                                            <CheckBox Style="{StaticResource ModernCheckBoxStyle}" Content="Installed Machines laden"
                      IsChecked="{Binding LoadInstalledMachines}" Margin="0,2,0,2"/>
                                        <CheckBox Style="{StaticResource ModernCheckBoxStyle}" Content="Postprozessor Ordner laden"
                      IsChecked="{Binding LoadPp}" Margin="0,2,0,2"/>
                                        <CheckBox Style="{StaticResource ModernCheckBoxStyle}" Content="Werkzeuge laden"
                      IsChecked="{Binding LoadTool}" Margin="0,2,0,2"/>
                                        <CheckBox Style="{StaticResource ModernCheckBoxStyle}" Content="Device laden"
                      IsChecked="{Binding LoadDevice}" Margin="0,2,0,2"/>
                                        <CheckBox Style="{StaticResource ModernCheckBoxStyle}" Content="Speed/Feed laden"
                      IsChecked="{Binding LoadFeed}" Margin="0,2,0,2"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Spracheinstellung"
          Grid.Row="1"
          Grid.Column="0"
          Margin="6,6,6,6"
          Padding="8">

                            <StackPanel Orientation="Horizontal"
                Height="30"
                VerticalAlignment="Center">

                                        <RadioButton Style="{StaticResource ModernRadioButtonStyle}" Content="Deutsch"
                     GroupName="Language"
                     IsChecked="{Binding IsGermanSelected}"
                     Margin="0,0,24,0"
                     VerticalAlignment="Center"/>

                                        <RadioButton Style="{StaticResource ModernRadioButtonStyle}" Content="Englisch"
                     GroupName="Language"
                     IsChecked="{Binding IsEnglishSelected}"
                     Margin="0"
                     VerticalAlignment="Center"/>
                            </StackPanel>
                        </GroupBox>


                                </StackPanel>

                                <StackPanel Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="1"
                Margin="14,28,0,0"
                VerticalAlignment="Top" Height="Auto">
                                    <StackPanel Margin="0,0,0,6">
                                    <Button Content="NX Starten"
                Command="{Binding StartCustomerNxCommand}"/>
                                    <CheckBox Style="{StaticResource ModernCheckBoxStyle}" Content="Mit NX X Lizenz Starten"
IsChecked="{Binding NxXCheck}" Margin="8,5,0,0"/>



                                    <CheckBox Style="{StaticResource ModernCheckBoxStyle}" Content="Mit Teamcenter Starten"
IsChecked="{Binding TcCheck}" Margin="8,5,0,6"/>
                                    </StackPanel>


                                    <Button Content="Ordner Öffnen"
                Command="{Binding OpenExplorerCommand}"
                Margin="6,14,6,6"/>

                            <Button Content="PP Öffnen"
                Command="{Binding OpenVsCodeCommand}"
                                    Visibility="{Binding PpVisibility}"
                Margin="6,14,6,6" Cursor="Hand"/>

                            <Button Content="Fork Öffnen"
                Command="{Binding OpenForkCommand}"
                                    Visibility="{Binding PpVisibility}"
                Margin="6,14,6,6"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="OOTB">
                    <Grid Margin="0,0,0,0" HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <GroupBox Header="NX Native starten" Grid.Row="0" Grid.ColumnSpan="2" Margin="6,29,6,12">
                            <Grid Margin="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="NX-Version:"
                                           Grid.Column="0" Margin="0,0,20,0"/>

                                <ComboBox ItemsSource="{Binding NativeVersions}"
                                          ScrollViewer.CanContentScroll="True"
                                          SelectedItem="{Binding SelectedNativeVersion}"
                                          Grid.Column="1"/>

                                <Button Content="NX Starten"
                                        Command="{Binding StartNxNativeCommand}"
                                        Grid.Column="2" Margin="20,6,6,6"/>
                            </Grid>
                        </GroupBox>

                                <GroupBox Header="Postbuilder starten" Grid.Row="1" Grid.ColumnSpan="2" Margin="6,12,6,12" Visibility="{Binding PpVisibility}">
                            <Grid Margin="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="PB-Version:"
                                           Grid.Column="0" Margin="0,0,20,0"/>

                                <ComboBox ItemsSource="{Binding PostbuilderVersions}"
                                          SelectedItem="{Binding SelectedPostbuilderVersion}"
                                          Grid.Column="1"
                                          ScrollViewer.CanContentScroll="True"/>

                                <Button Content="Postbuilder"
                                        Command="{Binding StartPostbuilderCommand}"
                                        Grid.Column="2" Margin="20,6,6,6"/>
                            </Grid>
                        </GroupBox>
                    </Grid>
                </TabItem>

                <TabItem Header="Neues Projekt">
                    <Grid Margin="8,0,8,0" Height="434">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="134"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                        <TextBlock Text="Kunde:" Grid.Column="0" Height="19"/>
                        <ComboBox ItemsSource="{Binding Customers}"
                                  Text="{Binding NewCustomer, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True"
                                  ScrollViewer.CanContentScroll="True"
                                  Grid.Row="0"
                                  Grid.Column="1" Margin="4,4,3,3" SelectionChanged="ComboBox_SelectionChanged"/>

                        <TextBlock Text="NX-Version:" Grid.Row="1" Grid.Column="0" Height="19"/>
                        <ComboBox ItemsSource="{Binding NativeVersions}"
                                  Text="{Binding NewVersion, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True"
                                  ScrollViewer.CanContentScroll="True"
                                  Grid.Row="1"
                                  Grid.Column="1" Margin="4,3,3,4"/>

                        <TextBlock Text="Maschine:" Grid.Row="2" Grid.Column="0" Height="18"/>
                        <TextBox Text="{Binding NewMachine, UpdateSourceTrigger=PropertyChanged}"
                                 Grid.Row="2"
                                 Grid.Column="1" Margin="3,3,3,3"/>

                        <TextBlock Text="Auftragsnummer:" Grid.Row="3" Grid.Column="0" Height="18"/>
                        <TextBox Text="{Binding NewOrderNumber, UpdateSourceTrigger=PropertyChanged}"
                                 Grid.Row="3"
                                 Grid.Column="1" Margin="3,3,3,3"/>

                        <TextBlock Text="Maschinentyp:"
                                       Grid.Row="4"
                                       Grid.Column="0"
                                       Margin="0,0,0,0"/>

                        <ComboBox ItemsSource="{Binding MachineTypes}"
                                      SelectedItem="{Binding SelectedMachineType}"
                                      Grid.Row="4"
                                      Grid.Column="3"/>

                        <TextBlock Text="Steuerung:"
                                       Grid.Row="5"
                                       Grid.Column="0"
                                       Margin="0,0,0,0"/>

                        <ComboBox ItemsSource="{Binding MachineControllers}"
                                      SelectedItem="{Binding SelectedController}"
                                      Grid.Row="5"
                                      Grid.Column="3"/>
                        
                                <CheckBox Style="{StaticResource ModernCheckBoxStyle}" Content="Vollständige CAM Umgebung erzeugen"
IsChecked="{Binding ComplexEnvRequired}" Grid.Row="6" Grid.Column="2" Margin="0,5,0,0"/>

                                <Button Content="Projekt erstellen"
                                Command="{Binding CreateProjectCommand}"
                                Grid.Row="7"
                                Grid.Column="1"
                                Width="170"
                                HorizontalAlignment="Left" Margin="6,27,0,6"/>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
            </Grid>
    </Border>
</Window>