<Window x:Class="NXStartCenter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NX Start Center"
        Height="630"
        Width="733"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgMain}"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="False">

    <Border BorderBrush="#3A3A3A"
        BorderThickness="1"
        CornerRadius="10"
        Background="Transparent"
        ClipToBounds="True">
        <Grid>

            <Grid>
                <Image Source="/resources/images/duhGroup_Logo.png"
               Stretch="UniformToFill"/>

                <DockPanel Background="Transparent">
                    <!-- Titelleiste und restlicher Inhalt -->
                </DockPanel>
            </Grid>
            
        <DockPanel>
            <Grid DockPanel.Dock="Top"
      Height="36"
      Background="#1E1E1E"
      MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="45"/>
                <ColumnDefinition Width="45"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="NX Start Center"
               VerticalAlignment="Center"
               Margin="12,0,0,0"
               Foreground="White"
               FontWeight="SemiBold"/>

            <Button Grid.Column="1"
            Content="—"
            FontSize="16"
            Background="Transparent"
            Foreground="White"
            BorderThickness="0"
            Click="Minimize_Click">

                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>

                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D2D2D"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Grid.Column="2"
            Content="✕"
            FontSize="14"
            Background="Transparent"
            Foreground="White"
            BorderThickness="0"
            Click="Close_Click">

                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>

                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C42B1C"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>


        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Datei">
                <MenuItem Header="Aktualisieren" Command="{Binding RefreshCommand}"/>
                <Separator/>
                <MenuItem Header="Beenden" Click="Exit_Click"/>
            </MenuItem>

            <MenuItem Header="Lizenz">
                <MenuItem Header="Lizenzdatei öffnen" Command="{Binding OpenLicenseFileCommand}"/>
                <MenuItem Header="LMTools starten" Command="{Binding StartLmToolsCommand}"/>
            </MenuItem>

            <MenuItem Header="Einstellungen">
                <MenuItem Header="Einstellungen öffnen" Command="{Binding OpenSettingsCommand}"/>
                <MenuItem Header="Einstellungen speichern" Command="{Binding SaveSettingsCommand}"/>
            </MenuItem>

            <MenuItem Header="Start Batches">
                <MenuItem Header="Startbatch öffnen" Command="{Binding OpenMainBatch}"/>
                        <MenuItem Header="Kundenbatch öffnen" Command="{Binding OpenCustomerBatch}"/>
                        <MenuItem Header="Developerbatch öffnen" Command="{Binding OpenMainBatch}"/>
            </MenuItem>

            <MenuItem Header="Info" Command="{Binding ShowInfoCommand}"/>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem Width="90">
                <TextBlock Text="{Binding StatusText}"
                   Foreground="{StaticResource TextMuted}"
                   TextTrimming="CharacterEllipsis"
                   ToolTip="{Binding StatusText}"/>
            </StatusBarItem>

            <Separator/>

            <StatusBarItem Width="430">
                <TextBlock Text="{Binding CurrentProjectPath}"
                   Foreground="{StaticResource TextMuted}"
                   TextTrimming="CharacterEllipsis"
                   ToolTip="{Binding CurrentProjectPath}"/>
            </StatusBarItem>

            <StatusBarItem HorizontalAlignment="Right" Width="140">
                <TextBlock Text="{Binding CurrentUser}"
                   Foreground="{StaticResource TextMuted}"
                   TextTrimming="CharacterEllipsis"
                   ToolTip="{Binding CurrentUser}"/>
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="14">

            <TabControl Margin="0,-14,0,-14">

                <TabItem Header="NX Starten">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="226"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <GroupBox Header="Projekt auswählen" Grid.Row="0" Grid.Column="0" Margin="6,12,6,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="105"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Kunde:" Grid.Row="0" Grid.Column="0"/>
                                <ComboBox ItemsSource="{Binding Customers}"
                      SelectedItem="{Binding SelectedCustomer}"
                      Grid.Row="0"
                      Grid.Column="1"/>

                                <TextBlock Text="NX-Version:" Grid.Row="1" Grid.Column="0"/>
                                <ComboBox ItemsSource="{Binding Versions}"
                      SelectedItem="{Binding SelectedVersion}"
                      Grid.Row="1"
                      Grid.Column="1"/>

                                <TextBlock Text="Maschine:" Grid.Row="2" Grid.Column="0"/>
                                <ComboBox ItemsSource="{Binding Machines}"
                      SelectedItem="{Binding SelectedMachine}"
                      Grid.Row="2"
                      Grid.Column="1"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Ladeoptionen" Grid.Row="1" Grid.Column="0" Margin="6,0,6,12">
                            <StackPanel>
                                <CheckBox Content="Installed Machines laden"
                      IsChecked="{Binding LoadInstalledMachines}"/>
                                <CheckBox Content="Postprozessor Ordner laden"
                      IsChecked="{Binding LoadPp}"/>
                                <CheckBox Content="Werkzeuge laden"
                      IsChecked="{Binding LoadTool}"/>
                                <CheckBox Content="Device laden"
                      IsChecked="{Binding LoadDevice}"/>
                                <CheckBox Content="Speed/Feed laden"
                      IsChecked="{Binding LoadFeed}"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Spracheinstellung"
          Grid.Row="2"
          Grid.Column="0"
          Margin="6,6,6,6"
          Padding="8">

                            <StackPanel Orientation="Horizontal"
                Height="30"
                VerticalAlignment="Center">

                                <RadioButton Content="Deutsch"
                     GroupName="Language"
                     IsChecked="{Binding IsGermanSelected}"
                     Margin="0,0,24,0"
                     VerticalAlignment="Center"/>

                                <RadioButton Content="Englisch"
                     GroupName="Language"
                     IsChecked="{Binding IsEnglishSelected}"
                     Margin="0"
                     VerticalAlignment="Center"/>
                            </StackPanel>
                        </GroupBox>

                        <StackPanel Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="1"
                Margin="14,28,0,0"
                VerticalAlignment="Top" Height="240">

                            <Button Content="NX Starten"
                Command="{Binding StartCustomerNxCommand}"/>

                            <Button Content="Ordner Öffnen"
                Command="{Binding OpenExplorerCommand}"
                Margin="6,14,6,6"/>

                            <Button Content="PP Öffnen"
                Command="{Binding OpenVsCodeCommand}"
                Margin="6,14,6,6"/>

                            <Button Content="Fork Öffnen"
                Command="{Binding OpenForkCommand}"
                Margin="6,14,6,6"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="NX Native">
                    <Grid Margin="122,0,103,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="504*"/>
                            <ColumnDefinition Width="181*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <GroupBox Header="NX Native starten" Grid.Row="0" Grid.ColumnSpan="2" Margin="6,12,6,12">
                            <Grid Margin="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="105"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="145"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="NX-Version:"
                                           Grid.Column="0"/>

                                <ComboBox ItemsSource="{Binding NativeVersions}"
                                          SelectedItem="{Binding SelectedNativeVersion}"
                                          Grid.Column="1"/>

                                <Button Content="NX Starten"
                                        Command="{Binding StartNxNativeCommand}"
                                        Grid.Column="2"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Postbuilder starten" Grid.Row="1" Grid.ColumnSpan="2" Margin="6,12,6,12">
                            <Grid Margin="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="105"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="145"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="NX-Version:"
                                           Grid.Column="0"/>

                                <ComboBox ItemsSource="{Binding PostbuilderVersions}"
                                          SelectedItem="{Binding SelectedPostbuilderVersion}"
                                          Grid.Column="1"/>

                                <Button Content="Postbuilder"
                                        Command="{Binding StartPostbuilderCommand}"
                                        Grid.Column="2"/>
                            </Grid>
                        </GroupBox>
                    </Grid>
                </TabItem>

                <TabItem Header="Neues Projekt">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="134"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Kunde:" Grid.Column="0" Height="19"/>
                        <ComboBox ItemsSource="{Binding Customers}"
                                  Text="{Binding NewCustomer, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True"
                                  Grid.Row="0"
                                  Grid.Column="1" Margin="4,4,3,3"/>

                        <TextBlock Text="NX-Version:" Grid.Row="1" Grid.Column="0" Height="19"/>
                        <ComboBox ItemsSource="{Binding NativeVersions}"
                                  Text="{Binding NewVersion, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True"
                                  Grid.Row="1"
                                  Grid.Column="1" Margin="4,3,3,4"/>

                        <TextBlock Text="Maschine:" Grid.Row="2" Grid.Column="0" Height="18"/>
                        <TextBox Text="{Binding NewMachine, UpdateSourceTrigger=PropertyChanged}"
                                 Grid.Row="2"
                                 Grid.Column="1" Margin="3,3,3,3"/>

                        <TextBlock Text="Auftragsnummer:" Grid.Row="3" Grid.Column="0" Height="18"/>
                        <TextBox Text="{Binding NewOrderNumber, UpdateSourceTrigger=PropertyChanged}"
                                 Grid.Row="3"
                                 Grid.Column="1" Margin="3,3,3,3"/>

                        <TextBlock Text="Maschinentyp:"
                                       Grid.Row="4"
                                       Grid.Column="0"
                                       Margin="0,0,0,0"/>

                        <ComboBox ItemsSource="{Binding MachineTypes}"
                                      SelectedItem="{Binding SelectedMachineType}"
                                      Grid.Row="4"
                                      Grid.Column="3"/>

                        <TextBlock Text="Steuerung:"
                                       Grid.Row="5"
                                       Grid.Column="0"
                                       Margin="0,0,0,0"/>

                        <ComboBox ItemsSource="{Binding MachineControllers}"
                                      SelectedItem="{Binding SelectedController}"
                                      Grid.Row="5"
                                      Grid.Column="3"/>

                        <Button Content="Projekt erstellen"
                                Command="{Binding CreateProjectCommand}"
                                Grid.Row="6"
                                Grid.Column="1"
                                Width="170"
                                HorizontalAlignment="Left" Margin="6,27,0,6"/>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
            </Grid>
    </Border>
</Window>