<Window x:Class="NXStartCenter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="d.u.h. Start Center"
        Height="650"
        Width="920"
        MinHeight="650"
        MinWidth="920"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Loaded="Window_Loaded">

    <Border x:Name="RootBorder"
        BorderBrush="#33404D"
        BorderThickness="1"
        CornerRadius="14"
        Background="{StaticResource BgMain}"
        ClipToBounds="True"
        RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="RootScale" ScaleX="1" ScaleY="1"/>
                <TranslateTransform x:Name="RootTranslate" Y="0"/>
            </TransformGroup>
        </Border.RenderTransform>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
        Background="{StaticResource BgTop}"
        CornerRadius="14,14,0,0"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="42"/>
                        <ColumnDefinition Width="42"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <Image Source="pack://application:,,,/resources/images/duhGroup_Logo.ico"
                               Width="24" Height="24" Margin="0,0,10,0" IsHitTestVisible="False"/>
                        <TextBlock Text="d.u.h. Start Center" FontWeight="SemiBold" FontSize="14"/>
                    </StackPanel>

                    <Button Grid.Column="1" Content="—" Width="34" Height="26" Margin="0,5,4,5"
                            FontSize="16" Style="{StaticResource TitleBarButtonStyle}" Click="Minimize_Click"/>
                    <Button Grid.Column="2" Content="✕" Width="34" Height="26" Margin="0,5,8,5"
                            FontSize="13" Style="{StaticResource CloseTitleBarButtonStyle}" Click="Close_Click"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#18212A" BorderBrush="#313D49" BorderThickness="0,0,1,0">
                    <Grid Margin="14,18,14,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Image Source="pack://application:,,,/resources/images/duhGroup_Logo.png"
                               Width="120" Height="88" HorizontalAlignment="Left" Stretch="Uniform"
                               Opacity="0.85" Margin="25,0,0,18"/>

                        <ScrollViewer Grid.Row="1"
              Margin="0,8,0,0"    
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled"
              PanningMode="VerticalOnly">
                            <StackPanel>
                                <Button Style="{StaticResource SideNavButtonStyle}" IsEnabled="False" Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⌂" Style="{StaticResource NavIconTextStyle}"/>
                                    <TextBlock Text="Start Center"/>
                                </StackPanel>
                            </Button>
                                <Button Style="{StaticResource SideNavButtonStyle}" ToolTip="Läd die Kundenumgebungen neu" Command="{Binding RefreshCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="↻" Style="{StaticResource NavIconTextStyle}"/>
                                    <TextBlock Text="Aktualisieren"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SideNavButtonStyle}" Command="{Binding OpenSettingsCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚙" Style="{StaticResource NavIconTextStyle}"/>
                                    <TextBlock Text="Einstellungen"/>
                                </StackPanel>
                            </Button>
                            <Expander Header="Lizenz"
          Tag="🔑"
          Style="{StaticResource SideNavExpanderStyle}">
                                <StackPanel Width="156">
                                    <Button Content="Lizenzdatei öffnen"
                Command="{Binding OpenLicenseFileCommand}"
                Style="{StaticResource SideNavSubButtonStyle}"/>
                                    <Button Content="LMTOOLS starten"
                Command="{Binding StartLmToolsCommand}"
                Style="{StaticResource SideNavSubButtonStyle}"/>
                                </StackPanel>
                            </Expander>

                            <Expander Header="Batch Dateien"
          Tag="▶"
          Style="{StaticResource SideNavExpanderStyle}">
                                <StackPanel>
                                        <Button Content="Main Batch öffnen" ToolTip="Die Haupt Startbatch. Sie ruft die anderen beiden Batch dateien auf."
                Command="{Binding OpenMainBatch}"
                Style="{StaticResource SideNavSubButtonStyle}"/>
                                        <Button Content="Customer Batch öffnen" ToolTip="Kunden Startbatch"
                Command="{Binding OpenCustomerBatch}"
                Style="{StaticResource SideNavSubButtonStyle}" Cursor="Hand"/>
                                        <Button Content="User Batch öffnen" ToolTip="Die letzte aufgerufene Batch datei vor NX Start. Hier können nach belieben Änderungen vorgenommen werden, die nie überschrieben werden."
                Command="{Binding OpenDeveloperBatch}"
                Style="{StaticResource SideNavSubButtonStyle}" Cursor="Hand"/>
                                </StackPanel>
                            </Expander>
                            <Button Style="{StaticResource SideNavButtonStyle}" Command="{Binding ShowInfoCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="ⓘ" Style="{StaticResource NavIconTextStyle}"/>
                                    <TextBlock Text="Info"/>
                                </StackPanel>
                            </Button>
                            </StackPanel>
                        </ScrollViewer>

                        <StackPanel Grid.Row="2">
                            <Border Height="1" Background="#34414E" Margin="0,0,0,12"/>
                            <TextBlock Text="Angemeldet als" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,3"/>
                            <TextBlock Text="{Binding CurrentUser}" FontSize="13" TextTrimming="CharacterEllipsis" ToolTip="{Binding CurrentUser}"/>


                            <Border Height="1" Background="#34414E" Margin="0,14,0,12"/>
                            <TextBlock Text="{Binding HeaderInfo}" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="8,14,16,0">
                    <TabControl>
                        <TabItem Header="Custom" ToolTip="Hauptseite - Starten von NX mit einer angepassten Umgebung">
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="285"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="220" MaxHeight="220"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Style="{StaticResource CardStyle}" Grid.Row="0" Grid.Column="0" Margin="0,0,12,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="105"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="▣  Projekt auswählen" Style="{StaticResource SectionHeaderTextStyle}"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Kunde:" Margin="0,18,12,0"/>
                                        <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}"
                                                  ScrollViewer.CanContentScroll="True" Margin="0,14,0,0"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="NX-Version:" Margin="0,10,12,0"/>
                                        <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding Versions}" SelectedItem="{Binding SelectedVersion}"
                                                  ScrollViewer.CanContentScroll="True" Margin="0,8,0,0"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Maschine:" Margin="0,10,12,0"/>
                                        <ComboBox Grid.Row="3" Grid.Column="1" ItemsSource="{Binding Machines}" SelectedItem="{Binding SelectedMachine}"
                                                  ScrollViewer.CanContentScroll="True" Margin="0,8,0,0"/>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="0"
      Grid.RowSpan="3"
      Grid.Column="1"
      Margin="0,0,0,12" VerticalAlignment="Top">

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="260" MaxHeight="260"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Height="220" MaxHeight="220"
            Style="{StaticResource CardStyle}" VerticalAlignment="Top">

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                       Text="🚀  Startoptionen"
                       Style="{StaticResource SectionHeaderTextStyle}"/>

                                            <Button Grid.Row="1"
                    Command="{Binding StartCustomerNxCommand}"
                    Margin="0,16,0,14"
                    Height="46">
                                                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">
                                                    <TextBlock Text="▶"
                               FontSize="15"
                               Margin="0,0,10,0"/>
                                                    <TextBlock Text="NX Starten"
                               FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Button>

                                            <Border Grid.Row="2"
                    Style="{StaticResource InnerCardStyle}"
                    Padding="14,5,14,5"
                    VerticalAlignment="Center">

                                                <StackPanel VerticalAlignment="Top">

                                                    <CheckBox Style="{StaticResource ModernCheckBoxStyle}"
                              Content="Mit NX X Lizenz Starten"
                              IsChecked="{Binding NxXCheck}"
                              Margin="0,0,0,12"/>

                                                    <CheckBox Style="{StaticResource ModernCheckBoxStyle}"
                              Content="Mit Teamcenter Starten"
                              IsChecked="{Binding TcCheck}"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="1"
            Style="{StaticResource CardStyle}"
            Margin="0,10,0,0">

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                       Text="⚡  Aktionen"
                       Style="{StaticResource SectionHeaderTextStyle}"/>

                                            <StackPanel Grid.Row="1">

                                                <Button Style="{StaticResource ActionButtonStyle}"
                        Content="Ordner öffnen"
                        ToolTip="Öffnet den Ordner der aktuell ausgewählten Maschine"
                        Command="{Binding OpenExplorerCommand}"
                        Height="46"/>

                                                <Button Style="{StaticResource ActionButtonStyle}"
                        Content="PP öffnen"
                                                        ToolTip="Öffnet den PP Ordner des ausgewählten Ordners in VS Code"
                        Command="{Binding OpenVsCodeAndForkCommand}"
                        Visibility="{Binding PpVisibility}"
                        Height="46"/>

                                                <Button Style="{StaticResource ActionButtonStyle}"
                        Content="Fork öffnen"
                                                        ToolTip="Öffnet das Repository der ausgewählten Maschine in Fork"
                        Command="{Binding OpenForkCommand}"
                        Visibility="{Binding PpVisibility}"
                        Height="46"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                                    <Border Style="{StaticResource CardStyle}" Grid.Row="1" Grid.Column="0" Margin="0,11,12,0" Visibility="{Binding PpVisibility}" Padding="16,16,16,16">
                                    <StackPanel>
                                        <TextBlock Text="↓  Ladeoptionen" Style="{StaticResource SectionHeaderTextStyle}"/>
                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                                <CheckBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource ModernCheckBoxStyle}" Content="Gesamtes Resource Verzeichnis" ToolTip="Macht nur Sinn wenn eine Vollständige CAM Umgebung installiert ist." IsChecked="{Binding LoadFullResourceDir}" Margin="0,0,8,9"/>
                                                <CheckBox Grid.Row="1" Grid.Column="0" Style="{StaticResource ModernCheckBoxStyle}" Content="Installed Machines" ToolTip="Läd die Maschine aus dem installed_machines Verzeichne" IsChecked="{Binding LoadInstalledMachines}" Margin="0,0,8,9"/>
                                                <CheckBox Grid.Row="2" Grid.Column="0" Style="{StaticResource ModernCheckBoxStyle}" Content="Postprozessor Ordner" ToolTip="Läd die Postprozessoren aus dem postprocessor verzeichnis (Für alte umgebungen und Postbuilder PP's)" IsChecked="{Binding LoadPp}" Margin="0,0,8,9"/>
                                                <CheckBox Grid.Row="1" Grid.Column="1" Style="{StaticResource ModernCheckBoxStyle}" Content="Werkzeuge" IsChecked="{Binding LoadTool}" ToolTip="Läd die Werkzeuge aus der Umgebung" Margin="0,0,0,9"/>
                                                <CheckBox Grid.Row="2" Grid.Column="1" Style="{StaticResource ModernCheckBoxStyle}" Content="Device" IsChecked="{Binding LoadDevice}" ToolTip="Läd die Devices aus der Umgebung" Margin="0,0,8,9"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}" Grid.Row="2" Grid.Column="0" Margin="0,11,12,12">
                                    <StackPanel>
                                        <TextBlock Text="🌐  Spracheinstellung" Style="{StaticResource SectionHeaderTextStyle}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                            <RadioButton Style="{StaticResource ModernRadioButtonStyle}" Content="Deutsch" GroupName="Language" IsChecked="{Binding IsGermanSelected}" Margin="0,0,34,0"/>
                                            <RadioButton Style="{StaticResource ModernRadioButtonStyle}" Content="Englisch" GroupName="Language" IsChecked="{Binding IsEnglishSelected}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                    </StackPanel>
                            </Grid>
                        </TabItem>

                        <TabItem Header="OOTB" ToolTip="NX ohne angepasster Umgebung starten">
                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="240"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Style="{StaticResource CardStyle}" Grid.Row="0" Grid.Column="0" Margin="0,0,12,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="150"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="NX-Version:" Grid.Column="0"/>
                                        <ComboBox ItemsSource="{Binding NativeVersions}" SelectedItem="{Binding SelectedNativeVersion}" Grid.Column="1" ScrollViewer.CanContentScroll="True"/>
                                        <Button Content="NX Starten" Command="{Binding StartNxNativeCommand}" Grid.Column="2" Margin="12,0,0,0"/>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource CardStyle}" Grid.Row="1" Grid.Column="0" Margin="0,0,12,12" Visibility="{Binding PpVisibility}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="150"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Postbuilder-Version:" Grid.Column="0"/>
                                        <ComboBox ItemsSource="{Binding PostbuilderVersions}" SelectedItem="{Binding SelectedPostbuilderVersion}" Grid.Column="1" ScrollViewer.CanContentScroll="True"/>
                                        <Button Content="PB Starten" Command="{Binding StartPostbuilderCommand}" Grid.Column="2" Margin="12,0,0,0"/>
                                    </Grid>
                                </Border>

                            </Grid>
                        </TabItem>

                        <TabItem Header="Neues Projekt" ToolTip="Anlegen einer neuen angepassten Umgebung oder einer neuen Maschine">
                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="285"/>
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource CardStyle}" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,12,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="145"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="✚  Neues Projekt" Style="{StaticResource SectionHeaderTextStyle}" Margin="0,0,0,10"/>

                                        <TextBlock Text="Kunde:*" ToolTip="Auswahl oder eingabe des Kundennamens" Grid.Row="1" Grid.Column="0"/>
                                        <ComboBox ItemsSource="{Binding Customers}" Text="{Binding NewCustomer, UpdateSourceTrigger=PropertyChanged}" IsEditable="True" ScrollViewer.CanContentScroll="True" Grid.Row="1" Grid.Column="1" SelectionChanged="ComboBox_SelectionChanged"/>

                                        <TextBlock Text="NX-Version:*" ToolTip="Auswahl oder eingabe der NX Version" Grid.Row="2" Grid.Column="0"/>
                                        <ComboBox ItemsSource="{Binding NativeVersions}" Text="{Binding NewVersion, UpdateSourceTrigger=PropertyChanged}" IsEditable="True" ScrollViewer.CanContentScroll="True" Grid.Row="2" Grid.Column="1"/>

                                        <TextBlock Text="Maschine:" ToolTip="Name der Maschine die angelegt werden soll" Grid.Row="3" Grid.Column="0"/>
                                        <TextBox Text="{Binding NewMachine, UpdateSourceTrigger=PropertyChanged}" Grid.Row="3" Grid.Column="1"/>

                                        <TextBlock Text="Auftragsnummer:" Grid.Row="4" Grid.Column="0"/>
                                        <TextBox Text="{Binding NewOrderNumber, UpdateSourceTrigger=PropertyChanged}" Grid.Row="4" Grid.Column="1"/>

                                        <TextBlock Text="Maschinentyp:" ToolTip="Wird für die Einträge in den .dat Dateien benötigt." Grid.Row="5" Grid.Column="0"/>
                                        <ComboBox ItemsSource="{Binding MachineTypes}" SelectedItem="{Binding SelectedMachineType}" Grid.Row="5" Grid.Column="1"/>

                                        <TextBlock Text="Steuerung:" ToolTip="Wird für die Einträge in den .dat Dateien benötigt." Grid.Row="6" Grid.Column="0"/>
                                        <ComboBox ItemsSource="{Binding MachineControllers}" SelectedItem="{Binding SelectedController}" Grid.Row="6" Grid.Column="1"/>

                                        <StackPanel Grid.Row="7" Grid.Column="1" Margin="0,12,0,0">
                                            <CheckBox Style="{StaticResource ModernCheckBoxStyle}" Content="Vollständige CAM Umgebung erzeugen" ToolTip="Wenn diese option nicht gesetzt ist, wird nur eine simple Umgebung erzeugt. Ist eher für PP Entwickler interressant." IsChecked="{Binding ComplexEnvRequired}" Margin="0,0,0,12"/>
                                            <Button Content="Projekt erstellen" Command="{Binding CreateProjectCommand}" Width="190" HorizontalAlignment="Left"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Grid>

            <Border Grid.Row="2" Background="#121A22" BorderBrush="#313D49" BorderThickness="0,1,0,0" CornerRadius="0,0,14,14">
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="16" Height="16" Fill="{Binding StatusColor}" Margin="0,0,9,0"/>
                        <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" TextTrimming="CharacterEllipsis" ToolTip="{Binding StatusText}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding CurrentProjectPath}" Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Right" TextTrimming="CharacterEllipsis" ToolTip="{Binding CurrentProjectPath}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
