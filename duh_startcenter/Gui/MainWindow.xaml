<Window x:Class="NXStartCenter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NX Start Center"
        Height="720"
        Width="1100"
        MinHeight="620"
        MinWidth="950"
        WindowStartupLocation="CenterScreen">

    <DockPanel Background="{StaticResource BgMain}">

        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Datei">
                <MenuItem Header="Aktualisieren" Command="{Binding RefreshCommand}"/>
                <Separator/>
                <MenuItem Header="Beenden" Click="Exit_Click"/>
            </MenuItem>

            <MenuItem Header="Lizenz">
                <MenuItem Header="Lizenzdatei öffnen" Command="{Binding OpenLicenseFileCommand}"/>
                <MenuItem Header="LMTools starten" Command="{Binding StartLmToolsCommand}"/>
            </MenuItem>

            <MenuItem Header="Einstellungen">
                <MenuItem Header="Einstellungen öffnen" Command="{Binding OpenSettingsCommand}"/>
                <MenuItem Header="Einstellungen speichern" Command="{Binding SaveSettingsCommand}"/>
            </MenuItem>

            <MenuItem Header="Info" Command="{Binding ShowInfoCommand}"/>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextMuted}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding CurrentUser}" Foreground="{StaticResource TextMuted}"/>
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="410"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- LINKE SEITE -->
            <StackPanel Grid.Column="0">

                <TabControl>
                    <TabItem Header="Projekt weiterarbeiten">
                        <Grid Margin="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Kunde:" Grid.Row="0" Grid.Column="0"/>
                            <ComboBox ItemsSource="{Binding Customers}"
                                  SelectedItem="{Binding SelectedCustomer}"
                                      Background="{StaticResource BgInput}"
          Foreground="{StaticResource TextMain}"
          TextElement.Foreground="{StaticResource TextMain}"
                                  Grid.Row="0"
                                  Grid.Column="1"/>

                            <TextBlock Text="NX-Version:" Grid.Row="1" Grid.Column="0"/>
                            <ComboBox ItemsSource="{Binding Versions}"
                                  SelectedItem="{Binding SelectedVersion}"
                                      Background="{StaticResource BgInput}"
          Foreground="{StaticResource TextMain}"
          TextElement.Foreground="{StaticResource TextMain}"
                                  Grid.Row="1"
                                  Grid.Column="1"/>

                            <TextBlock Text="Maschine:" Grid.Row="2" Grid.Column="0"/>
                            <ComboBox ItemsSource="{Binding Machines}"
                                  SelectedItem="{Binding SelectedMachine}"
                                      Background="{StaticResource BgInput}"
          Foreground="{StaticResource TextMain}"
          TextElement.Foreground="{StaticResource TextMain}"
                                  Grid.Row="2"
                                  Grid.Column="1"/>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Neues Projekt anlegen">
                        <Grid Margin="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Kunde:" Grid.Row="0" Grid.Column="0"/>
                            <ComboBox ItemsSource="{Binding Customers}"
                                  Text="{Binding NewCustomer}"
                                  IsEditable="True"
                                  Grid.Row="0"
                                  Grid.Column="1"/>

                            <TextBlock Text="NX-Version:" Grid.Row="1" Grid.Column="0"/>
                            <ComboBox ItemsSource="{Binding NativeVersions}"
                                  Text="{Binding NewVersion}"
                                  IsEditable="True"
                                  Grid.Row="1"
                                  Grid.Column="1"/>

                            <TextBlock Text="Maschine:" Grid.Row="2" Grid.Column="0"/>
                            <TextBox Text="{Binding NewMachine}" Grid.Row="2" Grid.Column="1"/>

                            <TextBlock Text="Auftrag:" Grid.Row="3" Grid.Column="0"/>
                            <TextBox Text="{Binding NewOrderNumber}" Grid.Row="3" Grid.Column="1"/>

                            <Button Content="Projekt erstellen"
                                Command="{Binding CreateProjectCommand}"
                                Grid.Row="4"
                                Grid.Column="1"
                                HorizontalAlignment="Left"/>
                        </Grid>
                    </TabItem>
                </TabControl>

                <GroupBox Header="Ladeoptionen">
                    <StackPanel>
                        <CheckBox Content="Installed Machines laden"
                              IsChecked="{Binding LoadInstalledMachines}"/>
                        <CheckBox Content="Postprozessor ordner laden"
                              IsChecked="{Binding LoadPp}"/>
                        <CheckBox Content="Werkzeuge laden"
                              IsChecked="{Binding LoadTool}"/>
                        <CheckBox Content="Device laden"
                              IsChecked="{Binding LoadDevice}"/>
                        <CheckBox Content="Speed/Feed laden"
                              IsChecked="{Binding LoadFeed}"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Spracheinstellung">
                    <StackPanel>
                        <RadioButton Content="Deutsch"
                                 IsChecked="{Binding IsGermanSelected}"/>
                        <RadioButton Content="Englisch"
                                 IsChecked="{Binding IsEnglishSelected}"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>

            <!-- RECHTE SEITE -->
            <Grid Grid.Column="1" Margin="16,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="150"/>
                </Grid.RowDefinitions>

                <TextBlock Text="d.u.h"
                       FontSize="120"
                       FontWeight="Light"
                       Foreground="#0B6F94"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

                <Border Grid.Row="1"
                    Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderSoft}"
                    BorderThickness="1"
                    Padding="16"
                    Margin="6">

                    <TabControl>
                        <TabItem Header="NX Native starten">
                            <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <TextBlock Text="NX-Version:" Margin="0,0,8,0"/>
                                <ComboBox Width="160"
                                      ItemsSource="{Binding NativeVersions}"
                                      SelectedItem="{Binding SelectedNativeVersion}"/>
                                <Button Content="NX Starten"
                                    Command="{Binding StartNxNativeCommand}"
                                    Margin="16,4,4,4"/>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Postbuilder starten">
                            <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <TextBlock Text="NX-Version:" Margin="0,0,8,0"/>
                                <ComboBox Width="160"
                                      ItemsSource="{Binding PostbuilderVersions}"
                                      SelectedItem="{Binding SelectedPostbuilderVersion}"/>
                                <Button Content="Postbuilder"
                                    Command="{Binding StartPostbuilderCommand}"
                                    Margin="16,4,4,4"/>
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>

            <!-- UNTEN BUTTONLEISTE -->
            <StackPanel Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    Margin="0,12,0,0">

                <Button Content="NX Starten"
                    Command="{Binding StartCustomerNxCommand}"
                    Width="120"/>

                <Button Content="Ordner Öffnen"
                    Command="{Binding OpenExplorerCommand}"
                    Width="130"/>

                <Button Content="PP Öffnen"
                    Command="{Binding OpenVsCodeCommand}"
                    Width="120"/>

                <Button Content="Fork Öffnen"
                    Command="{Binding OpenForkCommand}"
                    Width="120"/>

                <Button Content="Aktualisieren"
                    Command="{Binding RefreshCommand}"
                    Width="130"/>
            </StackPanel>

        </Grid>
    </DockPanel>
</Window>