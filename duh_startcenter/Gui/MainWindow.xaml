<Window x:Class="NXStartCenter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NX Start Center"
        Height="720"
        Width="1100"
        MinHeight="620"
        MinWidth="950"
        WindowStartupLocation="CenterScreen">

    <DockPanel>

        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Datei">
                <MenuItem Header="Aktualisieren" Command="{Binding RefreshCommand}"/>
                <Separator/>
                <MenuItem Header="Beenden" Click="Exit_Click"/>
            </MenuItem>

            <MenuItem Header="_Tools">
                <MenuItem Header="Maschinenordner öffnen" Command="{Binding OpenExplorerCommand}"/>
                <MenuItem Header="Postprocessor in VS Code öffnen" Command="{Binding OpenVsCodeCommand}"/>
                <MenuItem Header="Fork öffnen" Command="{Binding OpenForkCommand}"/>
            </MenuItem>

            <MenuItem Header="_Lizenz">
                <MenuItem Header="Lizenzdatei öffnen" Command="{Binding OpenLicenseFileCommand}"/>
                <MenuItem Header="LMTools starten" Command="{Binding StartLmToolsCommand}"/>
            </MenuItem>

            <MenuItem Header="_Einstellungen">
                <MenuItem Header="Einstellungen öffnen" Command="{Binding OpenSettingsCommand}"/>
                <MenuItem Header="Einstellungen speichern" Command="{Binding SaveSettingsCommand}"/>
            </MenuItem>

            <MenuItem Header="_Hilfe">
                <MenuItem Header="Info" Command="{Binding ShowInfoCommand}"/>
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Top" Padding="16" Background="#1F2937">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="NX Start Center"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <TextBlock Text="{Binding HeaderInfo}"
                               Foreground="#D1D5DB"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Aktualisieren"
                        Command="{Binding RefreshCommand}"
                        Width="140"/>
            </Grid>
        </Border>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding CurrentUser}"/>
            </StatusBarItem>
        </StatusBar>

        <TabControl Margin="12">

            <TabItem Header="Projektauswahl">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="Bestehendes Projekt auswählen">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Kunde:" Grid.Row="0" Grid.Column="0"/>
                            <ComboBox ItemsSource="{Binding Customers}"
                                      SelectedItem="{Binding SelectedCustomer}"
                                      Grid.Row="0"
                                      Grid.Column="1"/>

                            <Button Content="Aktualisieren"
                                    Command="{Binding RefreshCommand}"
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Margin="8,4,0,4"/>

                            <TextBlock Text="NX-Version:" Grid.Row="1" Grid.Column="0"/>
                            <ComboBox ItemsSource="{Binding Versions}"
                                      SelectedItem="{Binding SelectedVersion}"
                                      Grid.Row="1"
                                      Grid.Column="1"/>

                            <TextBlock Text="Maschine:" Grid.Row="2" Grid.Column="0"/>
                            <ComboBox ItemsSource="{Binding Machines}"
                                      SelectedItem="{Binding SelectedMachine}"
                                      Grid.Row="2"
                                      Grid.Column="1"/>

                            <TextBlock Text="Projektpfad:" Grid.Row="3" Grid.Column="0"/>
                            <TextBlock Text="{Binding CurrentProjectPath}"
                                       Grid.Row="3"
                                       Grid.Column="1"
                                       Grid.ColumnSpan="2"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="NX Start">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="NX starten" Grid.Column="0">
                        <StackPanel Margin="8">
                            <TextBlock Text="Sprache:"/>
                            <ComboBox ItemsSource="{Binding Languages}"
                                      SelectedItem="{Binding SelectedLanguage}"
                                      Margin="0,4,0,12"/>

                            <TextBlock Text="Native-Version:"/>
                            <ComboBox ItemsSource="{Binding NativeVersions}"
                                      SelectedItem="{Binding SelectedNativeVersion}"
                                      Margin="0,4,0,12"/>

                            <TextBlock Text="Postbuilder-Version:"/>
                            <ComboBox ItemsSource="{Binding PostbuilderVersions}"
                                      SelectedItem="{Binding SelectedPostbuilderVersion}"
                                      Margin="0,4,0,12"/>

                            <Button Content="Kunden-NX starten"
                                    Command="{Binding StartCustomerNxCommand}"/>

                            <Button Content="NX Native starten"
                                    Command="{Binding StartNxNativeCommand}"/>

                            <Button Content="Postbuilder starten"
                                    Command="{Binding StartPostbuilderCommand}"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Startoptionen" Grid.Column="1">
                        <StackPanel Margin="8">
                            <CheckBox Content="PP laden"
                                      IsChecked="{Binding LoadPp}"
                                      Margin="0,6"/>

                            <CheckBox Content="Installed Machines laden"
                                      IsChecked="{Binding LoadInstalledMachines}"
                                      Margin="0,6"/>

                            <CheckBox Content="Tool laden"
                                      IsChecked="{Binding LoadTool}"
                                      Margin="0,6"/>

                            <CheckBox Content="Device laden"
                                      IsChecked="{Binding LoadDevice}"
                                      Margin="0,6"/>

                            <CheckBox Content="Feed laden"
                                      IsChecked="{Binding LoadFeed}"
                                      Margin="0,6"/>
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Neues Projekt">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <GroupBox Header="Neues Projekt anlegen" Margin="12">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Kunde:" Grid.Row="0" Grid.Column="0"/>
                            <ComboBox ItemsSource="{Binding Customers}"
                                      Text="{Binding NewCustomer, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True"
                                      Grid.Row="0"
                                      Grid.Column="1"/>

                            <TextBlock Text="NX-Version:" Grid.Row="1" Grid.Column="0"/>
                            <ComboBox ItemsSource="{Binding NativeVersions}"
                                      Text="{Binding NewVersion, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True"
                                      Grid.Row="1"
                                      Grid.Column="1"/>

                            <TextBlock Text="Maschine:" Grid.Row="2" Grid.Column="0"/>
                            <TextBox Text="{Binding NewMachine, UpdateSourceTrigger=PropertyChanged}"
                                     Grid.Row="2"
                                     Grid.Column="1"/>

                            <TextBlock Text="Auftragsnummer:" Grid.Row="3" Grid.Column="0"/>
                            <TextBox Text="{Binding NewOrderNumber, UpdateSourceTrigger=PropertyChanged}"
                                     Grid.Row="3"
                                     Grid.Column="1"/>

                            <TextBlock Text="Maschinentyp:"
                                       Grid.Row="0"
                                       Grid.Column="2"
                                       Margin="20,0,0,0"/>

                            <ComboBox ItemsSource="{Binding MachineTypes}"
                                      SelectedItem="{Binding SelectedMachineType}"
                                      Grid.Row="0"
                                      Grid.Column="3"/>

                            <TextBlock Text="Steuerung:"
                                       Grid.Row="1"
                                       Grid.Column="2"
                                       Margin="20,0,0,0"/>

                            <ComboBox ItemsSource="{Binding MachineControllers}"
                                      SelectedItem="{Binding SelectedController}"
                                      Grid.Row="1"
                                      Grid.Column="3"/>

                            <Button Content="Projekt erstellen"
                                    Command="{Binding CreateProjectCommand}"
                                    Grid.Row="4"
                                    Grid.Column="1"
                                    Width="180"
                                    HorizontalAlignment="Left"
                                    Margin="0,12,0,0"/>
                        </Grid>
                    </GroupBox>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>