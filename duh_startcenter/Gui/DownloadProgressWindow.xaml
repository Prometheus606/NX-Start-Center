<Window x:Class="NXStartCenter.DownloadProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update wird heruntergeladen"
        Width="400"
        Height="160"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgMain}"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Grid Margin="20"
      Background="{StaticResource BgMain}">
        <StackPanel>
            <TextBlock Text="Update wird heruntergeladen..."
                       FontSize="16"
                       Margin="0,0,0,15"/>

            <ProgressBar x:Name="DownloadProgressBar"
             Height="22"
             Minimum="0"
             Maximum="100"
             Background="#2D2D30"
             Foreground="#3B82F6"
             BorderBrush="#444"
             BorderThickness="1"/>

            <TextBlock x:Name="ProgressText"
                       Margin="0,10,0,0"
                       Text="0 %"/>
        </StackPanel>
    </Grid>
</Window>