<Window x:Class="NXStartCenter.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Einstellungen"
        Height="560"
        Width="850"
        MinHeight="500"
        MinWidth="760"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgMain}"
        Foreground="White">

    <DockPanel Margin="12">

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">

            <Button Content="Speichern"
                    Command="{Binding SaveSettingsCommand}"
                    Width="140"
                    Margin="0,0,8,0"/>

            <Button Content="Schließen"
                    Width="120"
                    Click="Close_Click"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="NX Installationspfad:" Grid.Row="0" Grid.Column="0"/>
                <TextBox Text="{Binding Settings.NxInstallationPath, UpdateSourceTrigger=PropertyChanged}"
                         Grid.Row="0"
                         Grid.Column="1"/>

                <TextBlock Text="Kundenumgebungen:" Grid.Row="1" Grid.Column="0"/>
                <TextBox Text="{Binding Settings.CustomerEnvironmentPath, UpdateSourceTrigger=PropertyChanged}"
                         Grid.Row="1"
                         Grid.Column="1"/>

                <TextBlock Text="Vorlage &amp; Toolbars:" Grid.Row="2" Grid.Column="0"/>
                <TextBox Text="{Binding Settings.TemplateRoot, UpdateSourceTrigger=PropertyChanged}"
         Grid.Row="2"
         Grid.Column="1"/>

                <TextBlock Text="Portal.bat (Teamcenter):" Grid.Row="3" Grid.Column="0"/>
                <TextBox Text="{Binding Settings.TcPath, UpdateSourceTrigger=PropertyChanged}"
         Grid.Row="3"
         Grid.Column="1"/>

                <TextBlock Text="Lizenzdatei:" Grid.Row="4" Grid.Column="0"/>
                <TextBox Text="{Binding Settings.LicencePath, UpdateSourceTrigger=PropertyChanged}"
                         Grid.Row="4"
                         Grid.Column="1"/>

                <TextBlock Text="LMTools:" Grid.Row="5" Grid.Column="0"/>
                <TextBox Text="{Binding Settings.LicenceServerPath, UpdateSourceTrigger=PropertyChanged}"
                         Grid.Row="5"
                         Grid.Column="1"/>

                <TextBlock Text="Fork.exe:" Grid.Row="6" Grid.Column="0"/>
                <TextBox Text="{Binding Settings.ForkPath, UpdateSourceTrigger=PropertyChanged}"
                         Grid.Row="6"
                         Grid.Column="1"/>

                <TextBlock Text="Rollenpfade (; getrennt):" Grid.Row="7" Grid.Column="0"/>
                <TextBox Text="{Binding Settings.RolesPath, UpdateSourceTrigger=PropertyChanged}"
                         Grid.Row="7"
                         Grid.Column="1"/>

                <TextBlock Text="Team:" Grid.Row="8" Grid.Column="0"/>
                <ComboBox ItemsSource="{Binding Teams}"
                          SelectedItem="{Binding Settings.Team}"
                          Grid.Row="8"
                          Grid.Column="1"/>


                <TextBlock Text="Editor:" Grid.Row="9" Grid.Column="0"/>
                <ComboBox ItemsSource="{Binding Editors}"
                          SelectedItem="{Binding Settings.Editor}"
                          Grid.Row="9"
                          Grid.Column="1"/>

                <CheckBox Style="{StaticResource ModernCheckBoxStyle}" Content="Startdatei debuggen"
                          IsChecked="{Binding Settings.StartNxWithDebug}"
                          Grid.Row="10"
                          Grid.Column="1"
                          Margin="0,8"/>

                <TextBlock Text="Config:" Grid.Row="11" Grid.Column="0"/>
                <TextBlock Text="{Binding ConfigPath}"
                           Grid.Row="11"
                           Grid.Column="1"
                           TextWrapping="Wrap"/>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>