<Window x:Class="NXStartCenter.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Einstellungen"
        Height="560"
        Width="850"
        MinHeight="500"
        MinWidth="760"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgMain}"
        Foreground="White">

    <DockPanel Margin="12">

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0" Cursor="">

            <Button Content="Verwerfen"
        Command="{Binding DiscardSettingsCommand}"
        Width="140"
        Margin="0,0,8,0" Background="#FFAD2A2A">

                <Button.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="Black"/>
                    </Style>
                </Button.Resources>

            </Button>

            <Button Content="Speichern"
                    Command="{Binding SaveSettingsCommand}"
                    Width="140"
                    Margin="0,0,8,0"/>

            <Button Content="Schließen"
                    Width="120"
                    Click="Close_Click"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="8">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- NX Installationspfad -->
                <TextBlock Text="NX Installationspfad:"
                           Grid.Row="0"
                           Grid.Column="0"
                           VerticalAlignment="Center"/>

                <Grid Grid.Row="0" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Text="{Binding Settings.NxInstallationPath, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Column="0"/>

                    <Button Grid.Column="1"
                            Background="Transparent"
                            Width="Auto"
                            Height="Auto"
                            Margin="6,0,0,0"
                            ToolTip="Ordner auswählen"
                            Command="{Binding BrowseNxInstallationPathCommand}">
                        <TextBlock Text="📁"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>
                </Grid>

                <!-- Kundenumgebungen -->
                <TextBlock Text="Kundenumgebungen:"
                           Grid.Row="1"
                           Grid.Column="0"
                           VerticalAlignment="Center"/>

                <Grid Grid.Row="1" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Text="{Binding Settings.CustomerEnvironmentPath, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Column="0"/>

                    <Button Grid.Column="1"
                                                        Background="Transparent"
                            Width="Auto"
Height="Auto"
                            Margin="6,0,0,0"
                            ToolTip="Ordner auswählen"
                            Command="{Binding BrowseCustomerEnvironmentCommand}">
                        <TextBlock Text="📁" FontSize="14"/>
                    </Button>
                </Grid>

                <!-- Vorlage & Toolbars -->
                <TextBlock Text="Vorlage &amp; Toolbars:"
                           Grid.Row="2"
                           Grid.Column="0"
                           VerticalAlignment="Center"/>

                <Grid Grid.Row="2" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Text="{Binding Settings.TemplateRoot, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Column="0"/>

                    <Button Grid.Column="1"
                                                        Background="Transparent"
                            Width="Auto"
Height="Auto"
                            Margin="6,0,0,0"
                            ToolTip="Ordner auswählen"
                            Command="{Binding BrowseTemplateRootCommand}">
                        <TextBlock Text="📁" FontSize="14"/>
                    </Button>
                </Grid>

                <!-- Portal.bat -->
                <TextBlock Text="Portal.bat (Teamcenter):"
                           Grid.Row="3"
                           Grid.Column="0"
                           VerticalAlignment="Center"/>

                <Grid Grid.Row="3" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Text="{Binding Settings.TcPath, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Column="0"/>

                    <Button Grid.Column="1"
                                                        Background="Transparent"
                            Width="Auto"
Height="Auto"
                            Margin="6,0,0,0"
                            ToolTip="Datei auswählen"
                            Command="{Binding BrowseTcPathCommand}">
                        <TextBlock Text="📄" FontSize="14"/>
                    </Button>
                </Grid>

                <!-- Lizenzdatei -->
                <TextBlock Text="Lizenzdatei:"
                           Grid.Row="4"
                           Grid.Column="0"
                           VerticalAlignment="Center"/>

                <Grid Grid.Row="4" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Text="{Binding Settings.LicencePath, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Column="0"/>

                    <Button Grid.Column="1"
                                                        Background="Transparent"
                            Width="Auto"
Height="Auto"
                            Margin="6,0,0,0"
                            ToolTip="Datei auswählen"
                            Command="{Binding BrowseLicencePathCommand}">
                        <TextBlock Text="📄" FontSize="14"/>
                    </Button>
                </Grid>

                <!-- LMTools -->
                <TextBlock Text="LMTools:"
                           Grid.Row="5"
                           Grid.Column="0"
                           VerticalAlignment="Center"/>

                <Grid Grid.Row="5" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Text="{Binding Settings.LicenceServerPath, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Column="0"/>

                    <Button Grid.Column="1"
                                                        Background="Transparent"
                            Width="Auto"
Height="Auto"
                            Margin="6,0,0,0"
                            ToolTip="Datei auswählen"
                            Command="{Binding BrowseLicenceServerPathCommand}">
                        <TextBlock Text="📄" FontSize="14"/>
                    </Button>
                </Grid>

                <!-- Fork.exe -->
                <TextBlock Text="Fork.exe:"
                           Grid.Row="6"
                           Grid.Column="0"
                           VerticalAlignment="Center"/>

                <Grid Grid.Row="6" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="AUto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Text="{Binding Settings.ForkPath, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Column="0"/>

                    <Button Grid.Column="1"
                                                        Background="Transparent"
                            Width="Auto"
Height="Auto"
                            Margin="6,0,0,0"
                            ToolTip="Datei auswählen"
                            Command="{Binding BrowseForkPathCommand}">
                        <TextBlock Text="📄" FontSize="14"/>
                    </Button>
                </Grid>

                <!-- Rollenpfade -->
                <TextBlock Text="Rollenpfade (; getrennt):"
                           Grid.Row="7"
                           Grid.Column="0"
                           VerticalAlignment="Center"/>

                <Grid Grid.Row="7" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="AUto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Text="{Binding Settings.RolesPath, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Column="0"/>

                    <Button Grid.Column="1"
                                                        Background="Transparent"
                            Width="Auto"
Height="Auto"
                            Margin="6,0,0,0"
                            ToolTip="Ordner auswählen"
                            Command="{Binding BrowseRolesPathCommand}">
                        <TextBlock Text="📁" FontSize="14"/>
                    </Button>
                </Grid>

                <!-- Team -->
                <TextBlock Text="Team:"
                           Grid.Row="8"
                           Grid.Column="0"
                           VerticalAlignment="Center"/>

                <ComboBox ItemsSource="{Binding Teams}"
                          Width="250"
                          SelectedItem="{Binding Settings.Team}"
                          Grid.Row="8"
                          Grid.Column="1" HorizontalAlignment="Left"/>

                <!-- Editor -->
                <TextBlock Text="Editor:"
                           Grid.Row="9"
                           Grid.Column="0"
                           VerticalAlignment="Center"/>

                <ComboBox ItemsSource="{Binding Editors}"
                          Width="250"
                          SelectedItem="{Binding Settings.Editor}"
                          Grid.Row="9"
                          Grid.Column="1" HorizontalAlignment="Left"/>

                <!-- Debug -->
                <CheckBox Style="{StaticResource ModernCheckBoxStyle}"
                          Content="Startdatei debuggen"
                          IsChecked="{Binding Settings.StartNxWithDebug}"
                          Grid.Row="10"
                          Grid.Column="1"
                          Margin="0,8"/>

                <!-- Config -->
                <TextBlock Text="Config:"
                           Grid.Row="11"
                           Grid.Column="0"
                           VerticalAlignment="Top"/>

                <TextBlock Text="{Binding ConfigPath}"
                           Grid.Row="11"
                           Grid.Column="1"
                           TextWrapping="Wrap"/>

            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>