<Window x:Class="NXStartCenter.View.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Einstellungen"
        Height="560"
        Width="850"
        MinHeight="500"
        MinWidth="760"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgMain}"
        Foreground="White">

    <DockPanel Margin="12">

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0" Cursor="">

            <Button Content="Verwerfen"
        Command="{Binding DiscardSettingsCommand}"
        Width="140"
        Margin="0,0,8,0" Background="#FFAD2A2A">

                <Button.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="Black"/>
                    </Style>
                </Button.Resources>

            </Button>

            <Button Content="Speichern"
                    Command="{Binding SaveSettingsCommand}"
                    Width="140"
                    Margin="0,0,8,0"/>

            <Button Content="Schließen"
                    Width="120"
                    Click="Close_Click"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="8" Cursor="">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Config -->
                <TextBlock Text="Config Datei:"
                           Grid.Row="0"
                           Grid.Column="0"
                           VerticalAlignment="Top"/>

                <TextBlock Text="{Binding ConfigPath}"
                           Grid.Row="0"
                           Grid.Column="1"
                           TextWrapping="Wrap"/>

                <!-- NX Installationspfad -->
                <TextBlock Text="NX Installationspfad:"
                           Grid.Row="1"
                           Grid.Column="0"
                           ToolTip="Installationsort der NX Versionen"
                           VerticalAlignment="Center"/>

                <Grid Grid.Row="1" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Text="{Binding Settings.NxInstallationPath, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Column="0"/>

                    <Button Grid.Column="1"
                            Background="Transparent"
                            Width="Auto"
                            Height="Auto"
                            Margin="6,0,0,0"
                            ToolTip="Ordner auswählen"
                            Command="{Binding BrowseNxInstallationPathCommand}">
                        <TextBlock Text="📁"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>
                </Grid>

                <!-- Kundenumgebungen -->
                <TextBlock Text="Kundenumgebungen:"
                           ToolTip="Installationsort der Kundenumgebungen"
                           Grid.Row="2"
                           Grid.Column="0"
                           VerticalAlignment="Center"/>

                <Grid Grid.Row="2" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Text="{Binding Settings.CustomerEnvironmentPath, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Column="0"/>

                    <Button Grid.Column="1"
                                                        Background="Transparent"
                            Width="Auto"
Height="Auto"
                            Margin="6,0,0,0"
                            ToolTip="Ordner auswählen"
                            Command="{Binding BrowseCustomerEnvironmentCommand}">
                        <TextBlock Text="📁" FontSize="14"/>
                    </Button>
                </Grid>

                <!-- Vorlage & Toolbars -->
                <TextBlock Text="Vorlage &amp; Toolbars:"
                           ToolTip="Installationsort der Vorlagedateien (Toolbars)"
                           Grid.Row="3"
                           Grid.Column="0"
                           VerticalAlignment="Center"/>

                <Grid Grid.Row="3" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Text="{Binding Settings.TemplateRoot, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Column="0"/>

                    <Button Grid.Column="1"
                                                        Background="Transparent"
                            Width="Auto"
Height="Auto"
                            Margin="6,0,0,0"
                            ToolTip="Ordner auswählen"
                            Command="{Binding BrowseTemplateRootCommand}">
                        <TextBlock Text="📁" FontSize="14"/>
                    </Button>
                </Grid>

                <!-- Portal.bat -->
                <TextBlock Text="Portal.bat (optional):"
                           ToolTip="Startdatei vom Teamcenter Rich Client (optional)"
                           Grid.Row="4"
                           Grid.Column="0"
                           VerticalAlignment="Center"/>

                <Grid Grid.Row="4" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Text="{Binding Settings.TcPath, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Column="0"/>

                    <Button Grid.Column="1"
                                                        Background="Transparent"
                            Width="Auto"
Height="Auto"
                            Margin="6,0,0,0"
                            ToolTip="Datei auswählen"
                            Command="{Binding BrowseTcPathCommand}">
                        <TextBlock Text="📄" FontSize="14"/>
                    </Button>
                </Grid>

                <!-- Lizenzdatei -->
                <TextBlock Text="Lizenzdatei:"
                           ToolTip="Pfad zur Lizenzdatei"
                           Grid.Row="5"
                           Grid.Column="0"
                           VerticalAlignment="Center"/>

                <Grid Grid.Row="5" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Text="{Binding Settings.LicencePath, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Column="0"/>

                    <Button Grid.Column="1"
                                                        Background="Transparent"
                            Width="Auto"
Height="Auto"
                            Margin="6,0,0,0"
                            ToolTip="Datei auswählen"
                            Command="{Binding BrowseLicencePathCommand}">
                        <TextBlock Text="📄" FontSize="14"/>
                    </Button>
                </Grid>

                <!-- LMTools -->
                <TextBlock Text="Lizenzserver (LMTools.exe):"
                           ToolTip="Pfad zum Lizenzserver (LMTools.exe)"
                           Grid.Row="6"
                           Grid.Column="0"
                           VerticalAlignment="Center"/>

                <Grid Grid.Row="6" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Text="{Binding Settings.LicenceServerPath, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Column="0"/>

                    <Button Grid.Column="1"
                                                        Background="Transparent"
                            Width="Auto"
Height="Auto"
                            Margin="6,0,0,0"
                            ToolTip="Datei auswählen"
                            Command="{Binding BrowseLicenceServerPathCommand}">
                        <TextBlock Text="📄" FontSize="14"/>
                    </Button>
                </Grid>

                <!-- Rollenpfade -->
                <TextBlock Text="Rollenpfade (; getrennt):"
                           ToolTip="Pfade zu den Benutzerdefinierten rollen die zugänglich sein sollen."
                           Grid.Row="8"
                           Grid.Column="0"
                           VerticalAlignment="Center"/>

                <Grid Grid.Row="8" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="AUto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Text="{Binding Settings.RolesPath, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Column="0"/>

                    <Button Grid.Column="1"
                                                        Background="Transparent"
                            Width="Auto"
Height="Auto"
                            Margin="6,0,0,0"
                            ToolTip="Ordner auswählen"
                            Command="{Binding BrowseRolesPathCommand}">
                        <TextBlock Text="📁" FontSize="14"/>
                    </Button>
                </Grid>

                <!-- Team -->
                <TextBlock Text="Team:"
                           ToolTip="Je nach Team sind unterschiedliche Features verfügbar."
                           Grid.Row="9"
                           Grid.Column="0"
                           VerticalAlignment="Center"/>

                <ComboBox ItemsSource="{Binding Teams}"
                          Width="250"
                          SelectedItem="{Binding Settings.Team}"
                          Grid.Row="9"
                          Grid.Column="1" HorizontalAlignment="Left"/>

                <!-- Editor -->
                <TextBlock Text="Editor:"
                           Grid.Row="10"
                           Grid.Column="0"
                           VerticalAlignment="Center"/>

                <ComboBox ItemsSource="{Binding Editors}"
                          Width="250"
                          SelectedItem="{Binding Settings.Editor}"
                          Grid.Row="10"
                          Grid.Column="1" HorizontalAlignment="Left"/>

                <!-- Debug -->
                <CheckBox Style="{StaticResource ModernCheckBoxStyle}"
                          Content="Startdatei debuggen"
                          ToolTip="Beim starten von NX wird die Console angezeigt."
                          IsChecked="{Binding Settings.StartNxWithDebug}"
                          Grid.Row="11"
                          Grid.Column="1"
                          Margin="0,8"/>
                
                <CheckBox Style="{StaticResource ModernCheckBoxStyle}"
          Content="Repository im Fork Automatisch mit VS Code starten"
                          ToolTip="Beim Klick auf den Button 'PP Öffnen' zusätzlich Fork öffnen."
          IsChecked="{Binding Settings.OpenVsCodeWithFork}"
                          Visibility="{Binding PpVisibility}"
          Grid.Row="12"
          Grid.Column="1"
          Margin="0,8" Cursor="Hand"/>
                
                <CheckBox Style="{StaticResource ModernCheckBoxStyle}"
          Content="Pullen erinnerung zeigen beim öffnen von Fork"
                          ToolTip="Die Erinnerung zum Pullen ein- oder ausschalten."
          IsChecked="{Binding Settings.ShowPullReminder}"
          Visibility="{Binding PpVisibility}"
          Grid.Row="13"
          Grid.Column="1"
          Margin="0,8" Cursor="Hand"/>

            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>